generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Gender {
  MALE
  FEMALE
  NON_BINARY
  PREFER_NOT_TO_SAY
}

model User {
  id                    String                 @id @map("id")
  name                  String                 @map("name")
  email                 String                 @map("email")
  emailVerified         Boolean                @default(false) @map("email_verified")
  image                 String?                @map("image")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  phoneNumber           String?                @map("phone_number")
  phoneNumberVerified   Boolean?               @map("phone_number_verified")
  role                  String?                @map("role")
  banned                Boolean?               @default(false) @map("banned")
  banmessage            String?                @map("ban_message")
  banExpires            DateTime?              @map("ban_expires")
  coins                 Int                    @default(0) @map("coins")
  callLanguage          String?                @default("kn") @map("call_language")
  sessions              Session[]
  accounts              Account[]
  participants          Participant[]
  groupMembers          GroupMember[]
  sentMessages          Message[]
  media                 Media[]
  metadata              Json                   @default("{}") @map("metadata") @db.JsonB
  profile               Profile?
  payoutProfile         PayoutProfile?
  fundAccounts          FundAccount[]
  participantLogs       ParticipantLog[]
  addresses             UserAddress[]
  wallets               Wallet[]
  followers             Follow[]               @relation("Followers")
  following             Follow[]               @relation("Following")
  coinOrders            CoinOrder[]
  ordersAsBuyer         ProductOrder[]         @relation("OrderBuyer")
  ordersAsRecipient     ProductOrder[]         @relation("OrderRecipient")
  giftsSent             Gift[]                 @relation("GiftSender")
  giftsReceived         Gift[]                 @relation("GiftRecipient")
  userBlocksSent        UserBlock[]            @relation("BlocksSent")
  userBlocksReceived    UserBlock[]            @relation("BlocksReceived")
  wishlistProducts      WishlistProduct[]
  cart                  Cart?
  notificationsSent     NotificationCampaign[]
  verificationRequest   IdentityVerification?
  reviewedVerifications IdentityVerification[] @relation("AdminReviewer")

  callsInitiated   LiveRoom[] @relation("CallInitiator")
  callsReceived    LiveRoom[] @relation("CallReceiver")
  reportsSubmitted Report[]   @relation("ReportsSubmitted")
  reportsReceived  Report[]   @relation("ReportsReceived")

  // Social Media
  posts        Post[]
  postLikes    PostLike[]
  postComments PostComment[]
  postViews    PostView[]

  @@unique([email])
  @@unique([phoneNumber])
  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime @map("expires_at")
  token          String   @map("token")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  userId         String   @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonatedBy String?  @map("impersonated_by")
  fcmToken       String?  @default("") @map("fcm_token")
  metadata       Json     @default("{}") @map("metadata") @db.JsonB

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?   @map("scope")
  password              String?   @map("password")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String   @map("identifier")
  value      String   @map("value")
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([identifier])
  @@map("verification")
}

model UserAddress {
  id            String   @id
  recipientName String   @map("recipient_name")
  phoneNumber   String   @map("phone_number")
  addressLine1  String   @map("address_line1")
  addressLine2  String   @map("address_line2")
  landmark      String?  @map("landmark")
  city          String   @map("city")
  stateRegion   String   @map("state_region")
  pincode       String   @map("pincode")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  userId        String   @map("user_id")
  metadata      Json     @default("{}") @map("metadata") @db.JsonB

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_address")
}

model Profile {
  id        String    @id
  username  String    @unique @map("username")
  bio       String?   @map("bio")
  location  String?   @map("location")
  gender    Gender?   @map("gender")
  followers Int       @default(0) @map("followers")
  following Int       @default(0) @map("following")
  posts     Int       @default(0) @map("posts")
  lastSeen  DateTime? @map("last_seen")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  metadata  Json      @default("{}") @map("metadata") @db.JsonB
  interests String[]  @default([]) @map("interests")

  user User @relation(fields: [id], references: [id], onDelete: Cascade)

  @@map("profile")
}

model Follow {
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  follower    User     @relation("Followers", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  metadata    Json     @default("{}") @map("metadata") @db.JsonB

  @@unique([followerId, followingId])
  @@map("follow")
}

enum WalletType {
  COIN
  EARNING
}

model Wallet {
  id         String     @id
  userId     String     @map("user_id")
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletType WalletType @map("wallet_type")
  balance    Decimal    @default(0) @map("balance") @db.Decimal(15, 2)
  updatedAt  DateTime   @updatedAt @map("updated_at")
  metadata   Json       @default("{}") @map("metadata") @db.JsonB

  transactions Transaction[]

  @@unique([userId, walletType])
  @@index([userId])
  @@map("wallet")
}

enum TransactionCategory {
  DEPOSIT
  SPEND
  EARN
  WITHDRAWAL
  REFUND
}

enum TransactionType {
  CREDIT
  DEBIT
  ADJUSTMENT
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
}

enum ReferenceType {
  GIFT
  CALL
  REFUND
  WITHDRAWAL
  IAP_PURCHASE
}

model Transaction {
  id               String              @id
  walletId         String              @map("wallet_id")
  category         TransactionCategory @map("category")
  type             TransactionType     @map("type")
  amount           Decimal             @map("amount") @db.Decimal(15, 2)
  description      String?             @map("description")
  referenceId      String?             @map("reference_id")
  referenceType    ReferenceType?      @map("reference_type")
  paymentgatewayId String?             @map("payment_gateway_id")
  status           TransactionStatus   @map("status")
  metadata         Json                @default("{}") @map("metadata") @db.JsonB

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  wallet    Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)

  // New Relation: Call Context
  liveRoomId String?   @map("live_room_id")
  liveRoom   LiveRoom? @relation(fields: [liveRoomId], references: [id])

  // coin order (in-app purchase)
  coinOrder CoinOrder? @relation("CoinOrderTransaction")

  // New Relation: Specific Participant Log (Reverse of ParticipantLog.transaction)
  participantLog ParticipantLog?
  reports        Report[]

  @@index([walletId])
  @@index([category])
  @@index([walletId, category])
  @@map("transaction")
}

model Conversation {
  id           String        @id @default(cuid())
  name         String?       @map("name")
  isGroup      Boolean       @default(false) @map("is_group")
  participants Participant[]
  messages     Message[]
  createdAt    DateTime      @default(now()) @map("created_at")
  groupId      String?       @unique @map("group_id")
  group        Group?        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  liveRooms    LiveRoom[]
  metadata     Json          @default("{}") @map("metadata") @db.JsonB

  @@map("conversation")
}

model Participant {
  id             String       @id @default(cuid())
  userId         String       @map("user_id")
  conversationId String       @map("conversation_id")
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  lastReadAt     DateTime     @default(now()) @map("last_read_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  metadata       Json         @default("{}") @map("metadata") @db.JsonB

  @@unique([userId, conversationId])
  @@index([conversationId])
  @@map("participant")
}

model Group {
  id           String        @id @default(cuid())
  name         String        @map("name")
  logo         String?       @map("logo")
  description  String?       @map("description")
  members      GroupMember[]
  conversation Conversation?
  metadata     Json          @default("{}") @map("metadata") @db.JsonB

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  reports   Report[]

  @@map("group")
}

model GroupMember {
  id       String @id @default(cuid())
  userId   String @map("user_id")
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupId  String @map("group_id")
  group    Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  metadata Json   @default("{}") @map("metadata") @db.JsonB

  role      GROUP_MEMBERSHIP @default(MEMBER) @map("role")
  createdAt DateTime         @default(now()) @map("created_at")

  @@map("group_member")
}

enum GROUP_MEMBERSHIP {
  ADMIN
  MEMBER
}

enum MessageAction {
  INSERT
  UPDATE
  DELETE
}

enum MessageContentType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  STICKER
  CONTACT
  LOCATION
  REACTION
  SYSTEM
  CALL
  UNKNOWN
}

model Message {
  id             String             @id @default(cuid())
  timestamp      DateTime           @map("timestamp")
  contentType    MessageContentType @default(TEXT) @map("content_type")
  content        Json?              @map("content") @db.JsonB
  metadata       Json               @default("{}") @map("metadata") @db.JsonB
  message        String?            @map("message")
  action         MessageAction      @default(INSERT) @map("action")
  senderId       String?            @map("sender_id")
  sender         User?              @relation(fields: [senderId], references: [id], onDelete: Cascade)
  conversationId String             @map("conversation_id")
  conversation   Conversation       @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  replyToId      String?            @map("reply_to_id")
  replyTo        Message?           @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies        Message[]          @relation("MessageReplies")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  deletedAt      DateTime?          @map("deleted_at")
  reports        Report[]

  @@index([conversationId])
  @@index([senderId])
  @@index([timestamp])
  @@map("message")
}

enum MediaStatus {
  PENDING
  CONFIRMED
}

model Media {
  id          String      @id @default(cuid())
  key         String      @unique @map("key")
  filename    String      @map("filename")
  mimeType    String      @map("mime_type")
  size        Int?        @map("size")
  uploaderId  String      @map("uploader_id")
  uploader    User        @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  status      MediaStatus @default(PENDING) @map("status")
  expiresAt   DateTime    @map("expires_at")
  confirmedAt DateTime?   @map("confirmed_at")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  metadata    Json        @default("{}") @map("metadata") @db.JsonB

  @@index([status, expiresAt])
  @@index([uploaderId])
  @@map("media")
}

enum OrderType {
  IAP_PURCHASE
  PRODUCT_PURCHASE
}

model CoinOrder {
  id     String @id @default(cuid()) @map("coin_order_id")
  userId String @map("user_id")

  // Link to Catalog (The "100 Coins Pack")
  iapItemId String @map("iap_item_id")

  // Verification
  platform           StorePlatform @map("platform")
  storeTransactionId String        @unique @map("store_transaction_id")
  purchaseToken      String        @map("purchase_token")

  status        OrderStatus @default(PENDING_PAYMENT)
  createdAt     DateTime    @default(now()) @map("created_at")
  metadata      Json        @default("{}") @map("metadata") @db.JsonB
  transactionId String?     @unique @map("transaction_id")

  transaction Transaction? @relation("CoinOrderTransaction", fields: [transactionId], references: [id])

  user User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  item IAPItem @relation(fields: [iapItemId], references: [id])

  @@map("coin_orders")
}

enum StorePlatform {
  ANDROID
  IOS
}

model ProductOrder {
  id String @id @default(cuid()) @map("product_order_id")

  // 1. Core Info
  buyerId     String  @map("buyer_id")
  recipientId String? @map("recipient_id")
  isGift      Boolean @default(false) @map("is_gift")
  giftMessage String? @map("gift_message")

  // 2. Financials (The "Invoice")
  razorpayOrderId   String  @unique @map("razorpay_order_id")
  razorpayPaymentId String? @unique @map("razorpay_payment_id")

  grandTotal Decimal @map("grand_total") @db.Decimal(10, 2)

  // 3. Status (High Level)
  status OrderStatus @default(PENDING_PAYMENT)

  // 4. Address Snapshot (OrderAddress holds the FK via orderId)
  shippingAddress OrderAddress?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  metadata  Json     @default("{}") @map("metadata") @db.JsonB

  // Relations
  items     ProductOrderItem[]
  buyer     User               @relation("OrderBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  recipient User?              @relation("OrderRecipient", fields: [recipientId], references: [id], onDelete: SetNull)

  @@map("product_orders")
}

model OrderAddress {
  id String @id @map("order_address_id")

  // 1. The Link (Belongs strictly to ONE order)
  orderId String @unique @map("product_order_id")

  // 2. The Snapshot Data
  fullName    String @map("full_name")
  phoneNumber String @map("phone_number")

  addressLine1 String  @map("address_line_1")
  addressLine2 String? @map("address_line_2")
  landmark     String? @map("landmark")
  city         String  @map("city")
  state        String  @map("state")
  postalCode   String  @map("postal_code")
  country      String  @default("IN") @map("country")

  // 3. Type (Optional: If you later split Billing vs Shipping)
  type AddressType @default(SHIPPING)

  createdAt DateTime @default(now()) @map("created_at")

  order ProductOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  metadata Json @default("{}") @map("metadata") @db.JsonB

  @@map("order_addresses")
}

enum AddressType {
  SHIPPING
  BILLING
}

model ProductOrderItem {
  id        String  @id @default(cuid()) @map("product_order_item_id")
  orderId   String  @map("product_order_id")
  productId String? @map("product_id")

  // 1. Snapshot
  productName  String  @map("product_name")
  productImage String? @map("product_image")
  productSku   String? @map("product_sku")

  // 2. Financials per Item
  quantity   Int     @default(1)
  unitPrice  Decimal @map("unit_price") @db.Decimal(10, 2)
  totalPrice Decimal @map("total_price") @db.Decimal(10, 2)

  // 3. Independent Lifecycle (Amazon Style)
  status OrderItemStatus @default(PENDING)

  // 4. Logistics (Specific to this item)
  shippingProvider String? @map("shipping_provider") // e.g., "BlueDart"
  trackingNumber   String? @map("tracking_number") // e.g., "123456789"

  // 5. Lifecycle Timestamps
  shippedAt         DateTime? @map("shipped_at")
  deliveredAt       DateTime? @map("delivered_at")
  cancelledAt       DateTime? @map("cancelled_at")
  returnRequestedAt DateTime? @map("return_requested_at")

  // 6. Metadata
  cancelmessage String? @map("cancel_message") // "Out of stock" or "User changed mind"

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  order   ProductOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product?     @relation(fields: [productId], references: [id], onDelete: SetNull)

  metadata Json @default("{}") @map("metadata") @db.JsonB

  @@index([status]) // Fast lookup: "Show me all Pending items"
  @@map("product_order_items")
}

// 1. Order Level: Focuses on Payment & Overall Health
enum OrderStatus {
  PENDING_PAYMENT // User hit checkout, hasn't paid
  PLACED // Paid successfully
  PARTIALLY_SHIPPED // Some items shipped, others pending
  COMPLETED // All items delivered
  CANCELLED // Entire order cancelled
}

// 2. Item Level: Focuses on the physical journey
enum OrderItemStatus {
  PENDING // Waiting for packing
  PACKED // Ready to ship
  SHIPPED // Handed to courier (Has tracking)
  DELIVERED // Customer received it
  CANCELLED // Out of stock / User cancelled just this item
  RETURN_REQUESTED // User wants to return
  RETURNED // Item received back at warehouse
  REFUNDED // Money returned for this item
}

model Product {
  id String @id @default(cuid()) @map("product_id")

  // 1. Core Info
  title       String @map("title")
  description String @map("description") @db.Text
  sku         String @unique @map("sku") // Stock Keeping Unit (e.g., "GIFT-BOX-001")

  // 2. Pricing (Decimal for precision)
  originalPrice   Decimal @map("original_price") @db.Decimal(10, 2)
  discountedPrice Decimal @map("discounted_price") @db.Decimal(10, 2)

  // 3. Media & Config
  images   String[] @map("images")
  giftable Boolean  @default(false) @map("giftable")

  // 4. Inventory Management (New)
  stockQuantity Int     @default(0) @map("stock_quantity")
  isActive      Boolean @default(true) @map("is_active") // To hide products without deleting them

  // 5. Wishlist
  wishlistEntries WishlistProduct[]
  cartEntries     CartItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  orderItems ProductOrderItem[]

  metadata Json @default("{}") @map("metadata") @db.JsonB

  @@map("products") // Plural convention is better for Postgres
}

model IAPItem {
  id String @id @default(cuid()) @map("iap_item_id")

  // 1. Product Details
  type        IAPType @default(COIN_PACK) @map("type") // PACK or GIFT
  title       String  @map("title")
  description String  @map("description")
  imageUrl    String  @map("image_url") // The visual (e.g., Rose icon)

  // 2. Value/Cost
  currency String  @default("INR") @map("currency")
  price    Decimal @map("price") // Display price (e.g. ₹99)

  // 3. Effect (What happens when bought?)
  coinValue Int @default(0) @map("coin_value") // If PACK: Buyer gets this. If GIFT: Recipient gets this (optional).

  // 4. Store Links
  playStoreId String? @unique @map("play_store_id")
  appStoreId  String? @unique @map("app_store_id")

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  gifts      Gift[] // Gifts sent using this Item
  coinOrders CoinOrder[] // Coin Packs bought using this Item

  metadata Json @default("{}") @map("metadata") @db.JsonB

  @@map("iap_items")
}

enum IAPType {
  COIN_PACK // Buyer gets coins (Self-consumption)
  DIGITAL_GIFT // Recipient gets the item/value (Transfer)
}

model Gift {
  id String @id @default(cuid()) @map("gift_id")

  // 1. Who?
  senderId    String @map("sender_id")
  recipientId String @map("recipient_id")
  iapItemId   String @map("iap_item_id")

  // 2. How was it paid?
  purchaseMethod PurchaseMethod @default(IAP) // IAP (Real Money) or WALLET (Coins)

  // 3. IAP Verification (If paid via Store)
  platform           StorePlatform? @map("platform") // ANDROID / IOS
  storeTransactionId String?        @unique @map("store_transaction_id") // Order ID
  purchaseToken      String?        @map("purchase_token") // For validation

  // 4. Wallet Transaction (If paid via Coins OR Recipient received Coins)
  walletTransactionId String? @map("wallet_transaction_id") // Link to the money movement

  // 5. Status
  status GiftStatus @default(PENDING) // PENDING -> DELIVERED (After IAP Verify)

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  sender    User    @relation("GiftSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient User    @relation("GiftRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  item      IAPItem @relation(fields: [iapItemId], references: [id])

  metadata Json @default("{}") @map("metadata") @db.JsonB

  @@index([recipientId])
  @@index([storeTransactionId])
  @@map("gifts")
}

enum GiftStatus {
  PENDING
  DELIVERED // Verified & Effects applied
  FAILED // IAP Verification failed
}

enum PurchaseMethod {
  IAP // Direct Store Purchase
  WALLET // Spent internal Coins
}

model WishlistProduct {
  userId    String   @map("user_id")
  productId String   @map("product_id")
  addedAt   DateTime @default(now()) @map("added_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([userId, productId])
  @@map("wishlist")
}

/// User's active shopping session.
/// Pattern: Singleton (1 User = 1 Cart).
model Cart {
  id String @id @map("user_id")

  // 1. Lifecycle
  // Use this to trigger "Abandoned Cart" emails if > 24 hours
  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user  User       @relation(fields: [id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  items CartItem[]

  @@map("carts") // Plural is standard for Postgres tables
}

model CartItem {
  id     String @id @default(cuid()) @map("cart_item_id")
  cartId String @map("cart_id")

  // 1. The Product
  productId String @map("product_id")

  // 2. User Intent (The "Missing" Fields)
  quantity Int @default(1)

  // [NEW] Partial Checkout: Only checkout items where isSelected = true
  isSelected Boolean @default(true) @map("is_selected")

  // [NEW] "Save For Later": If true, hide from checkout total, show in separate list
  isSaved Boolean @default(false) @map("is_saved")

  // [NEW] Variants: e.g. { "size": "M", "color": "Red" }
  attributes Json @default("{}") @map("attributes") @db.JsonB
  metadata   Json @default("{}") @map("metadata") @db.JsonB

  // 3. Auditing
  addedAt   DateTime @default(now()) @map("added_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Constraint: A Cart cannot have duplicate rows for the exact same SKU.
  // (If you use 'attributes' for variants, remove this unique constraint)
  @@unique([cartId, productId])
  @@index([cartId, isSelected]) // Fast lookup: "Get my checkout total"
  @@map("cart_items")
}

model PayoutProfile {
  id String @id // id of the user

  legalName         String @map("legal_name") // legal name of the user
  razorpayContactId String @unique @map("razorpay_contact_id") // razorpay contact id

  isVerified Boolean @default(false) @map("is_verified") // whether the payout profile is verified

  panHash   String @unique @map("pan_hash") // hash of the pan number
  panMasked String @map("pan_masked") // masked pan number

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  metadata  Json     @default("{}") @map("metadata") @db.JsonB

  user User @relation(fields: [id], references: [id], onDelete: Cascade)

  @@map("payout_profiles")
}

enum AccountType {
  vpa
  bank
}

model FundAccount {
  id String @id @map("razorpay_fund_account_id") // primary key

  userId String

  redactedVpa String @map("redacted_vpa") // since original will be send to razorpay
  vpaHash     String @map("vpa_hash") // hash of the vpa. if user enters the same vpa, we just set this account as active.

  isActive Boolean @default(true) @map("is_active") // whether the account is active

  createdAt DateTime @default(now()) @map("created_at") // immutable, no updatedAt

  accountType AccountType @default(vpa)
  metadata    Json        @default("{}") @map("metadata") @db.JsonB

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // TODO: partial index needs to be added, so only 1 entry for a user can be true
  @@unique([userId], name: "one_active_account", map: "one_active_account_idx")
  @@map("fund_accounts")
}

enum CallType {
  AUDIO
  VIDEO
}

enum CallStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
  ENDED
}

model LiveRoom {
  id String @id @default(cuid()) @map("live_room_id")

  conversationId String       @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  // 1. Config
  // Strict 1-on-1 participants
  initiatorId String @map("initiator_id")
  receiverId  String @map("receiver_id")

  callType CallType @map("call_type")

  status CallStatus @default(PENDING) @map("status")

  //
  callerAgoraToken   String @map("caller_agora_token")
  receiverAgoraToken String @map("receiver_agora_token")

  ratePerMinute        Decimal @default(0) @map("rate_per_minute") @db.Decimal(10, 2)
  earningRatePerMinute Decimal @default(0) @map("earning_rate_per_minute") @db.Decimal(10, 2)
  isBilled             Boolean @default(false) @map("is_billed")

  startedAt DateTime  @default(now()) @map("started_at")
  endedAt   DateTime? @map("ended_at")

  // 3. Close Context
  endmessage CallEndmessage? @map("end_message")

  // 4. Analytics (Aggregated when call ends)
  totalRevenue  Decimal @default(0) @map("total_revenue") // Sum of all boys' payments
  totalDuration Int     @default(0) @map("total_duration") // Room open duration

  // Relations
  initiator    User             @relation("CallInitiator", fields: [initiatorId], references: [id], onDelete: Cascade)
  receiver     User             @relation("CallReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  logs         ParticipantLog[]
  transactions Transaction[]
  metadata     Json             @default("{}") @map("metadata") @db.JsonB
  //TODO: (In SQL migration, add: WHERE is_active = true)
  reports      Report[]

  @@map("live_rooms")
}

enum CallEndmessage {
  COMPLETED
  REJECTED
  MISSED
  BUSY
  INSUFFICIENT_FUNDS
  NETWORK_ERROR
  CANCELLED
  BALANCE_EXHAUSTED
}

enum UserRole {
  SPEAKER
  LISTENER
}

model ParticipantLog {
  id         String @id @default(cuid()) @map("log_id")
  liveRoomId String @map("live_room_id")
  userId     String @map("user_id")

  // 1. Role & Rate Snapshot
  role         UserRole @default(LISTENER) // HOST (Girl) or LISTENER (Boy)
  rateSnapshot Decimal  @default(0) @map("rate_snapshot") // Price when HE joined

  // 2. The Timer (Socket Heartbeat)
  joinedAt   DateTime  @default(now()) @map("joined_at")
  leftAt     DateTime? @map("left_at") // Null = Currently in call
  lastPingAt DateTime  @default(now()) @map("last_ping_at") // Track network drops

  // 3. The Bill (Calculated on Exit)
  billableSeconds Int     @default(0) @map("billable_seconds")
  totalCost       Decimal @default(0) @map("total_cost") @db.Decimal(10, 2)
  earnings        Decimal @default(0) @map("earnings") @db.Decimal(10, 2)

  // 4. Transaction Link
  walletTransactionId String?      @unique @map("wallet_transaction_id")
  transaction         Transaction? @relation(fields: [walletTransactionId], references: [id])

  // 5. Exit Context
  disconnectmessage Disconnectmessage? @map("disconnect_message")

  room     LiveRoom @relation(fields: [liveRoomId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  metadata Json     @default("{}") @map("metadata") @db.JsonB

  @@index([userId, leftAt]) // "Is this user busy?"
  @@map("participant_logs")
}

model Report {
  id String @id @default(cuid()) @map("report_id")

  // 1. Who is reporting?
  reporterId String? @map("reporter_id")
  reporter   User?   @relation("ReportsSubmitted", fields: [reporterId], references: [id], onDelete: SetNull)

  // 1.1 Guest Reporting (For Grievances)
  guestName  String? @map("guest_name")
  guestEmail String? @map("guest_email")
  guestPhone String? @map("guest_phone")

  // 2. The Complaint
  message     String  @map("message") // e.g. "Harassment", "Scam"
  description String? @map("description") @db.Text
  evidence    Json?   @map("evidence") @db.JsonB // URLs to screenshots etc.

  // 2.1 Grievance Specifics
  isGrievance Boolean @default(false) @map("is_grievance")
  ticketId    String? @unique @map("ticket_id") // e.g. "GRV-2024-001"

  // 3. Status Workflow
  status     ReportStatus @default(PENDING) @map("status")
  resolution String?      @map("resolution") // Admin notes
  resolvedAt DateTime?    @map("resolved_at")

  // 4. Targets (Polymorphic-ish) - Only one should be set ideally
  targetUserId String? @map("target_user_id")
  targetUser   User?   @relation("ReportsReceived", fields: [targetUserId], references: [id], onDelete: SetNull)

  targetMessageId String?  @map("target_message_id")
  targetMessage   Message? @relation(fields: [targetMessageId], references: [id])

  targetLiveRoomId String?   @map("target_live_room_id")
  targetLiveRoom   LiveRoom? @relation(fields: [targetLiveRoomId], references: [id])

  targetGroupId String? @map("target_group_id")
  targetGroup   Group?  @relation(fields: [targetGroupId], references: [id])

  targetTransactionId String?      @map("target_transaction_id")
  targetTransaction   Transaction? @relation(fields: [targetTransactionId], references: [id])

  targetPostId String? @map("target_post_id")
  targetPost   Post?   @relation(fields: [targetPostId], references: [id])

  targetPostCommentId String?      @map("target_post_comment_id")
  targetPostComment   PostComment? @relation(fields: [targetPostCommentId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  metadata  Json     @default("{}") @map("metadata") @db.JsonB

  @@index([reporterId])
  @@index([status])
  @@map("reports")
}

enum ReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  DISMISSED
}

enum Disconnectmessage {
  USER_LEFT
  PEER_LEFT
  BALANCE_EXHAUSTED
  SOCKET_TIMEOUT
}

model NotificationCampaign {
  id String @id @default(cuid()) @map("campaign_id")

  // 1. Content (The Template)
  title    String  @map("title")
  body     String  @map("body")
  imageUrl String? @map("image_url")
  deepLink String? @map("deep_link") // e.g. "/profile/123" or "https://..."

  // 2. Configuration
  type    NotificationType @default(SYSTEM) @map("type")
  filters Json             @default("{}") @map("filters") @db.JsonB // Target: { "country": "IN", "last_active": "30d" }

  // 3. Execution Stats (Updated by your Background Job)
  targetUserCount Int @default(0) @map("target_user_count")
  successCount    Int @default(0) @map("success_count")
  failureCount    Int @default(0) @map("failure_count")

  // 4. Lifecycle
  status      CampaignStatus @default(DRAFT) @map("status")
  scheduledAt DateTime?      @map("scheduled_at") // If null, send immediately
  startedAt   DateTime?      @map("started_at") // Job picked up
  completedAt DateTime?      @map("completed_at") // Job finished

  // 5. Audit
  sentByUserId String?  @map("sent_by_user_id")
  metadata     Json     @default("{}") @map("metadata") @db.JsonB // Store "posthog_campaign_id" here
  createdAt    DateTime @default(now()) @map("created_at")

  // Relation
  sentBy User? @relation(fields: [sentByUserId], references: [id], onDelete: SetNull)

  @@index([type, status]) // Admin Dashboard: "Show me all Pending Marketing offers"
  @@index([createdAt]) // Admin Dashboard: "History"
  @@map("notification_campaigns")
}

enum NotificationType {
  MARKETING // Promos, Discounts
  SYSTEM // Maintenance alerts, TOS updates
  OFFER // Personalised offers
  UPDATE // App updates
}

enum CampaignStatus {
  DRAFT // Created but not ready
  SCHEDULED // Waiting for cron job
  PROCESSING // Currently sending (Job locked)
  COMPLETED // Finished
  FAILED // Job crashed
  CANCELLED // Stopped by admin
}

model UserBlock {
  // Composite ID: A user can block another specific user only once.
  blockerId String @map("blocker_id")
  blockedId String @map("blocked_id")

  createdAt DateTime @default(now()) @map("created_at")
  metadata  Json     @default("{}") @map("metadata") @db.JsonB

  // Relations
  blocker User @relation("BlocksSent", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("BlocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)

  @@id([blockerId, blockedId]) // Primary Key
  // Indexes for fast filtering
  @@index([blockerId]) // "Who have I blocked?" (My Blacklist)
  @@index([blockedId]) // "Who blocked me?" (To hide them from search results)
  @@map("user_blocks")
}

model IdentityVerification {
  id     String @id @default(cuid()) @map("verification_id")
  userId String @unique @map("user_id") // One active request per user

  // 1. The Proof
  selfieUrl String @map("selfie_url") // S3/R2 URL of the selfie

  // 2. Status
  status           VerificationStatus @default(PENDING) @map("status")
  rejectionmessage String?            @map("rejection_message") // Sent to user: "Face not visible"

  // 3. Admin Decision
  reviewedBy String?   @map("reviewed_by_admin_id") // Which admin decided?
  reviewedAt DateTime? @map("reviewed_at")

  // [NEW] Force Gender Feature
  // If admin detects mismatch, they set this. 
  // The system then updates User.gender = adminOverrideGender.
  adminOverrideGender Gender? @map("admin_override_gender")

  // 4. Metadata
  attempts Int  @default(1) @map("attempts")
  metadata Json @default("{}") @map("metadata") @db.JsonB // AI Confidence Score?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  admin User? @relation("AdminReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@index([status]) // Admin Dashboard: "Show me Pending requests"
  @@map("identity_verifications")
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
  CHANGES_REQUESTED // "Please retake with better lighting"
}

// ==========================================
// [NEW] Social Media (Feed & Interactions)
// ==========================================

enum ContentStatus {
  ACTIVE
  HIDDEN
  ARCHIVED
}

enum MediaType {
  IMAGE
  VIDEO
}

model Post {
  id            String        @id @default(cuid())
  userId        String        @map("user_id")
  caption       String        @default("") @map("caption")
  location      String?       @map("location")
  status        ContentStatus @default(ACTIVE) @map("status")
  allowComments Boolean       @default(true) @map("allow_comments")
  metadata      Json          @default("{}") @map("metadata") @db.JsonB
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  deletedAt     DateTime?     @map("deleted_at")

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  media        PostMedia[]
  likes        PostLike[]
  comments     PostComment[]
  views        PostView[]
  dailyMetrics PostDailyMetrics[]
  reports      Report[]

  @@index([userId])
  @@map("posts")
}

model PostMedia {
  id       String    @id @default(cuid())
  postId   String    @map("post_id")
  url      String    @map("url")
  type     MediaType @map("type")
  order    Int       @default(0) @map("order")
  metadata Json      @default("{}") @map("metadata") @db.JsonB

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("post_media")
}

model PostLike {
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  metadata  Json     @default("{}") @map("metadata") @db.JsonB

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
  @@map("post_likes")
}

model PostComment {
  id       String        @id @default(cuid())
  postId   String        @map("post_id")
  userId   String        @map("user_id")
  parentId String?       @map("parent_id")
  content  String        @map("content")
  status   ContentStatus @default(ACTIVE) @map("status")
  metadata Json          @default("{}") @map("metadata") @db.JsonB

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  post    Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  PostComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies PostComment[] @relation("CommentReplies")
  reports Report[]

  @@index([postId])
  @@index([parentId])
  @@map("post_comments")
}

model PostView {
  id        String   @id @default(cuid())
  postId    String   @map("post_id")
  userId    String?  @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  metadata  Json     @default("{}") @map("metadata") @db.JsonB

  post Post  @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("post_views")
}

model PostDailyMetrics {
  id          String   @id @default(cuid())
  postId      String   @map("post_id")
  date        DateTime @map("date") // Truncated to YYYY-MM-DD
  impressions Int      @default(0) @map("impressions")
  reach       Int      @default(0) @map("reach")
  likes       Int      @default(0) @map("likes")
  comments    Int      @default(0) @map("comments")
  shares      Int      @default(0) @map("shares")
  saves       Int      @default(0) @map("saves")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, date])
  @@map("post_daily_metrics")
}
